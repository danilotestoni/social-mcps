WP_CLIENT_ID=your_wordpress_app_client_id_here
WP_CLIENT_SECRET=your_wordpress_app_client_secret_here
WP_REDIRECT_URI=http://localhost:8765/callback
WP_ACCESS_TOKEN=    # Permanent token (no expiry), populated by oauth_setup.py
WP_SITE_ID=         # Site ID or domain (e.g. mysite.wordpress.com), populated by oauth_setup.py

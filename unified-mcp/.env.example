# ══ Servidor ══════════════════════════════════════════════════════════════════
# MCP_TRANSPORT: "stdio" para uso local (Claude Desktop / Claude Code lanzan el
# proceso), "streamable-http" para despliegue remoto (Render). Por defecto: stdio.
MCP_TRANSPORT=stdio
# PORT: puerto HTTP en modo streamable-http (Render lo inyecta automáticamente).
PORT=8000
# MCP_AUTH_TOKEN: OBLIGATORIO en despliegues públicos. Si está definido, toda
# petición HTTP debe llevar el header "Authorization: Bearer <token>".
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=

# ══ Activación de plataformas ═════════════════════════════════════════════════
# Pon a false las plataformas que no quieras usar: no registran sus tools y no
# se validan sus credenciales. Por defecto todas activadas.
ENABLE_LINKEDIN=true
ENABLE_FACEBOOK=true
ENABLE_INSTAGRAM=true
ENABLE_THREADS=true
ENABLE_WORDPRESS=true
ENABLE_X=true
ENABLE_FB_SHARE=true
# IMAGE_GEN es automático: se activa solo si GEMINI_API_KEY tiene valor.
# Descomenta para forzar: ENABLE_IMAGE_GEN=true

# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_TOKEN_EXPIRY=
LINKEDIN_PERSON_URN=

# ── Facebook (Page) ───────────────────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_TOKEN_EXPIRY=
FACEBOOK_PAGE_ID=

# ── Instagram ─────────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_TOKEN_EXPIRY=
INSTAGRAM_ACCOUNT_ID=

# ── Threads ───────────────────────────────────────────────────────────────────
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=
THREADS_TOKEN_EXPIRY=
THREADS_USER_ID=

# ── WordPress.com ─────────────────────────────────────────────────────────────
WP_CLIENT_ID=
WP_CLIENT_SECRET=
WP_ACCESS_TOKEN=
WP_SITE_ID=

# ── X / Twitter (Twikit — sin API oficial) ────────────────────────────────────
X_USERNAME=
X_PASSWORD=
X_EMAIL=

# ── Gemini (generación de imágenes — "nano banana") ──────────────────────────
# API key gratuita en https://aistudio.google.com/apikey
# Si está vacío, la tool generate_image no se registra.
GEMINI_API_KEY=
# Modelo opcional (por defecto gemini-2.5-flash-image)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ── Notifier (opcional) ───────────────────────────────────────────────────────
# Si se configura, se enviará un webhook POST con el mensaje de alerta
# cuando una acción requiera Playwright (X Twikit falla / fb_share siempre)
NOTIFY_WEBHOOK_URL=
